modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 23249
externalPort = 3000

[userenv]

[userenv.shared]
PHONEPE_SALT_INDEX = "1"
PHONEPE_BASE_URL = "https://api-preprod.phonepe.com/apis/pg-sandbox"
ADMIN_EMAIL = "admin@papillonethinics.com"
PHONEPE_MERCHANT_ID = "PGTESTPAYUAT"
PHONEPE_SALT_KEY = "099eb0cd-02cf-4dc2-a4c3-df3f7d563d2f"
ADMIN_PASSWORD = "Admin@Papillon2024"
JWT_SECRET = "papillon-jwt-secret-2024-change-in-production"
